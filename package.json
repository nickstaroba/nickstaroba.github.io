{
  "name": "nickstaroba.github.io",
  "version": "0.1.0",
  "private": true,
  "description": "A static website for a resume and a contact form.",
  "homepage": "https://github.com/nickstaroba/nickstaroba.github.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickstaroba/nickstaroba.github.io.git"
  },
  "license": "UNLICENSED",
  "author": "Nick Staroba",
  "scripts": {
    "build": "gulp build",
    "dev": "npm-run-all --parallel dev:*",
    "dev:serve": "live-server docs",
    "dev:watch": "gulp",
    "lint": "prettier './**/*.{css,html,js,json,jsx,md,scss,ts,tsx}' --write ; eslint '**/*.{js,jsx,ts,tsx}' --fix ; stylelint 'src/**/*.{css,scss}'",
    "release": "standard-version --commit-all"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "prepare-commit-msg": "git-hooks/prepare-commit-msg.sh ${HUSKY_GIT_PARAMS}",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-push": "npm run lint"
    }
  },
  "standard-version": {
    "scripts": {
      "postbump": "npm run build && git add ."
    }
  },
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@commitlint/cli": "11.0.0",
    "@commitlint/config-conventional": "11.0.0",
    "autoprefixer": "10.2.4",
    "del": "6.0.0",
    "ejs": "3.1.5",
    "eslint": "7.19.0",
    "eslint-config-airbnb-base": "14.2.1",
    "eslint-config-prettier": "7.2.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-simple-import-sort": "7.0.0",
    "gulp": "4.0.2",
    "gulp-cli": "2.3.0",
    "gulp-data": "1.3.1",
    "gulp-ejs": "5.1.0",
    "gulp-html-minifier-terser": "6.0.1",
    "gulp-postcss": "9.0.0",
    "gulp-rename": "2.0.0",
    "gulp-sass": "4.1.0",
    "http-server": "0.12.3",
    "husky": "4.3.8",
    "lint-staged": "10.5.4",
    "live-server": "1.2.1",
    "normalize.css": "8.0.1",
    "npm-run-all": "4.1.5",
    "postcss": "8.2.4",
    "prettier": "2.2.1",
    "sass": "1.32.6",
    "standard-version": "9.1.0",
    "stylelint": "13.9.0",
    "stylelint-config-recommended": "3.0.0",
    "stylelint-config-sass-guidelines": "7.1.0"
  }
}
