{
  "name": "nickstaroba.github.io",
  "version": "0.1.3",
  "private": true,
  "description": "A static website for a resume and a contact form.",
  "homepage": "https://github.com/nickstaroba/nickstaroba.github.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickstaroba/nickstaroba.github.io.git"
  },
  "license": "UNLICENSED",
  "author": "Nick Staroba",
  "scripts": {
    "build": "gulp build",
    "dev": "npm-run-all --parallel dev:*",
    "dev:serve": "live-server docs",
    "dev:watch": "gulp",
    "lint": "prettier './**/*.{css,html,js,json,jsx,md,scss,ts,tsx}' --write ; eslint '**/*.{js,jsx,ts,tsx}' --fix ; stylelint 'src/**/*.{css,scss}'",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "release": "standard-version --commit-all"
  },
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@commitlint/cli": "12.1.4",
    "@commitlint/config-conventional": "12.1.4",
    "autoprefixer": "10.2.6",
    "del": "6.0.0",
    "ejs": "3.1.6",
    "eslint": "7.29.0",
    "eslint-config-airbnb-base": "14.2.1",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-simple-import-sort": "7.0.0",
    "gulp": "4.0.2",
    "gulp-cli": "2.3.0",
    "gulp-data": "1.3.1",
    "gulp-ejs": "5.1.0",
    "gulp-html-minifier-terser": "6.0.1",
    "gulp-postcss": "9.0.0",
    "gulp-rename": "2.0.0",
    "gulp-sass": "5.0.0",
    "husky": "6.0.0",
    "lint-staged": "11.0.0",
    "live-server": "1.2.1",
    "normalize.css": "8.0.1",
    "npm-run-all": "4.1.5",
    "postcss": "8.3.5",
    "prettier": "2.3.2",
    "sass": "1.35.1",
    "standard-version": "9.3.0",
    "stylelint": "13.13.1",
    "stylelint-config-recommended": "5.0.0",
    "stylelint-config-sass-guidelines": "8.0.0"
  }
}
